# ============================================================
# HALAL-BITE — Environment Variables
# ============================================================
# IMPORTANT:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env to Git — it's already in .gitignore
#   4. This .env.example file IS safe to commit (no real secrets)
# ============================================================

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
POSTGRES_USER=halalbiteuser
POSTGRES_PASSWORD=halalbitepass          # TODO: change in production

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_PASSWORD=halalbiteRedis123         # TODO: change in production

# ------------------------------------------------------------
# Stripe — get these from https://dashboard.stripe.com
# Use TEST keys for local dev (start with sk_test_)
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET
STRIPE_PLATFORM_ACCOUNT_ID=acct_REPLACE_WITH_YOUR_PLATFORM_ID

# ------------------------------------------------------------
# Email (Mailtrap is great for local dev — free fake inbox)
# Sign up at https://mailtrap.io and grab your SMTP credentials
# ------------------------------------------------------------
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=REPLACE_WITH_MAILTRAP_USERNAME
MAIL_PASSWORD=REPLACE_WITH_MAILTRAP_PASSWORD

# ------------------------------------------------------------
# Keycloak (local dev only — do NOT use these in production)
# ------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
